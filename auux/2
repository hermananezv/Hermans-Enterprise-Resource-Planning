// Es un concepto del negocio. Protege sus propias reglas.
export class Precio {
  constructor(
    private readonly cantidad: number,
    private readonly moneda: string
  ) {
    // EL VO SE VALIDA A SÍ MISMO
    if (cantidad < 0) {
      throw new Error('Un helado no puede tener precio negativo.');
    }
    if (!['EUR', 'USD'].includes(moneda)) {
      throw new Error('Moneda no aceptada.');
    }
  }

  // Comportamiento de negocio: sumar dos precios devuelve un NUEVO Precio (Inmutabilidad)
  sumar(otroPrecio: Precio): Precio {
    if (this.moneda !== otroPrecio.moneda) throw new Error('Monedas distintas');
    return new Precio(this.cantidad + otroPrecio.cantidad, this.moneda);
  }
}

¿Cómo trabajan juntos?

Normalmente, hacen equipo.

    El usuario envía un JSON a tu API.

    Tu Controlador recibe ese JSON y lo mete en un DTO (la caja de cartón).

    El Controlador le pasa ese DTO al Caso de Uso.

    El Caso de Uso abre la caja (el DTO), saca los datos en bruto y los usa para construir Value Objects y Entidades. Si los datos del DTO eran basura (ej. precio negativo), el Value Object lanzará un error y detendrá el proceso.

